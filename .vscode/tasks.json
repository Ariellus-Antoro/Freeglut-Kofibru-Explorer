{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build active project",
            "command": "C:/MinGW/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/*.cpp",
                "${workspaceFolder}/src/core/*.cpp",
                "${workspaceFolder}/src/utils/*.cpp",
                "${workspaceFolder}/src/objects/*.cpp", // Memastikan file Gedung.cpp temanmu ikut di-build

                "-o",
                "${workspaceFolder}/bin/main.exe",
                
                // 1. Daftarkan root include lokal agar core/, utils/, objects/ bisa dicari langsung
                "-I${workspaceFolder}/include",
                
                // 2. Prioritaskan folder include FreeGLUT eksternal milikmu yang sukses
                "-ID:/Kuliah/Semester_7/freeglut/include",
                
                // 3. Tembak langsung folder lib eksternal milikmu yang arsitekturnya cocok
                "-LD:/Kuliah/Semester_7/freeglut/lib", 
                
                "-lfreeglut",
                "-lopengl32",
                "-lglu32",
                "-lgdi32",
                "-lwinmm"
            ],
            "options": {
                "cwd": "C:/MinGW/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Kompilasi modular OpenGL FreeGLUT untuk Tim"
        }
    ]
}